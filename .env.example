# Server Configuration
PORT=8080
NODE_ENV=development

# DeepInfra AI (Qwen 72B / Llama)
DEEPINFRA_API_KEY=

# Google Gemini AI (fallback when DeepInfra is down — free tier available)
GOOGLE_AI_API_KEY=

# Database Configuration (Render PostgreSQL)
# Get this from your Render dashboard: Database > Internal Database URL
DATABASE_URL=postgresql://sahla4eco_db_user:FLDPHutpZp8DYg0gV8gfVGgOHcSdQ95k@dpg-d5l1upngi27c738gvr1g-a.oregon-postgres.render.com/sahla4eco_db
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173

# API Configuration
PING_MESSAGE=ping

# Database (when you add one)
# DATABASE_URL=postgresql://user:password@localhost:5432/ecopro

# Render API (for health dashboard gauges — CPU, RAM, DB metrics)
# Get API key from: https://dashboard.render.com → Account Settings → API Keys
# Database ID: from your Postgres dashboard URL (/postgres/<id>)
# Service ID: from your web service dashboard URL (/srv/<id>)
RENDER_API_KEY=
RENDER_DATABASE_ID=
RENDER_SERVICE_ID=

# Email Service (Resend — required for forgot password, welcome emails)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
# REQUIRED: Must be a verified domain in your Resend account
# e.g. "Sahla4Eco <noreply@sahla4eco.com>"
# If not set, falls back to onboarding@resend.dev which ONLY works for the Resend account owner
EMAIL_FROM=Sahla4Eco <noreply@yourdomain.com>

# Gmail SMTP for sending verification codes
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-google-app-password

# Payment Gateway (when you add one)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# Google Sheets API (when you add integration)
# GOOGLE_SHEETS_PRIVATE_KEY=...
# GOOGLE_SHEETS_CLIENT_EMAIL=...

# Cloudinary (for persistent image storage)
# Get credentials from: https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# IP Intelligence — Fraud Detection APIs (free tiers available)
# IPQualityScore: https://www.ipqualityscore.com/ — free tier: 5K queries/month
# Required for VPN/proxy/Tor/fraud scoring on every order
IPQS_KEY=
# ipinfo.io: https://ipinfo.io/ — free tier: 50K queries/month
# Provides ISP, ASN, org, geo data per IP
IPINFO_TOKEN=
# AbuseIPDB: https://www.abuseipdb.com/ — free tier: 1K queries/day
# Blacklist checking for known abusive IPs
ABUSEIPDB_KEY=

# ─────────────────────────────────────────────────────────
# PLATFORM SHARED CHANNELS (your pages — given to all clients by default)
# Update these whenever you change your own pages/bots.
# ─────────────────────────────────────────────────────────

# Your Telegram bot (all client accounts use this bot unless they add their own)
PLATFORM_TELEGRAM_BOT_TOKEN=
PLATFORM_TELEGRAM_BOT_USERNAME=

# Your Facebook/Messenger page (all clients use this page by default)
PLATFORM_FB_PAGE_ID=
PLATFORM_FB_PAGE_ACCESS_TOKEN=

# Your WhatsApp Business account (shared with all clients)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=sahla4eco_wa_verify_2026
WHATSAPP_BUSINESS_ACCOUNT_ID=

